{
  "entities": {
    "User": {
      "title": "User",
      "description": "Staff members using the CRM",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff"] },
        "createdAt": { "type": "integer" },
        "updatedAt": { "type": "integer" }
      },
      "required": ["name", "email", "role", "createdAt", "updatedAt"]
    },
    "Lead": {
      "title": "Lead",
      "description": "Potential customers from Website or other sources",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "requirement": { "type": "string" },
        "completionTime": { "type": "string" },
        "source": { "type": "string", "enum": ["Facebook", "Website", "Khác"] },
        "status": { "type": "string", "enum": ["new", "contacted", "qualified", "lost"] },
        "assignedTo": { "type": "string" },
        "createdAt": { "type": "integer" },
        "updatedAt": { "type": "integer" }
      },
      "required": ["name", "phone", "completionTime", "source", "status", "createdAt", "updatedAt"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Converted leads or direct customers",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "type": { "type": "string", "enum": ["Khách lẻ", "Nhà thầu", "Kiến trúc sư", "Đại lý"] },
        "history": { "type": "string" },
        "createdAt": { "type": "integer" },
        "updatedAt": { "type": "integer" }
      },
      "required": ["name", "phone", "type", "createdAt", "updatedAt"]
    },
    "Quotation": {
      "title": "Quotation",
      "description": "Quotation containing product list",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerType": { "type": "string", "enum": ["lead", "customer"] },
        "products": { "type": "array" },
        "total": { "type": "number" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "integer" },
        "updatedAt": { "type": "integer" }
      },
      "required": ["customerId", "customerName", "customerType", "products", "total", "createdBy", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles for CRM staff"
    },
    "/leads/{leadId}": {
      "schema": { "$ref": "#/entities/Lead" },
      "description": "Leads repository"
    },
    "/customers/{customerId}": {
      "schema": { "$ref": "#/entities/Customer" },
      "description": "Customer repository"
    },
    "/quotations/{quotationId}": {
      "schema": { "$ref": "#/entities/Quotation" },
      "description": "Quotations repository"
    }
  }
}
